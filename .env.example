# -------------------------------------------------------------------
# APPLICATION
# -------------------------------------------------------------------
APP_ENV=development
APP_NAME=TaskManager
APP_DEBUG=true

# -------------------------------------------------------------------
# DATABASE
# -------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskmanager

# -------------------------------------------------------------------
# SECURITY / JWT
# -------------------------------------------------------------------
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7